# proxyflow Backend Environment Variables
# Copy this file to .env and fill in your values

# Server ports
PORT=8000
PROXY_PORT=8001
HOST=localhost

# JWT secret (change this to a secure random string in production)
JWT_SECRET=proxyflow-secret-change-me

# Anthropic API Key for AI features (Sprint 5)
# Get your key from: https://console.anthropic.com/
# Without this key, AI features will show a friendly "not configured" message
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Encrypts per-user AI API keys saved from Personal Settings.
# Use a stable, strong random value in production. Changing it makes existing saved keys unreadable.
AI_CREDENTIAL_SECRET=replace-with-a-strong-random-secret
